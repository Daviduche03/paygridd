# Server
NODE_ENV=development
PORT=3003
HOST=127.0.0.1

# Single Postgres database (Drizzle)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/paygrid

# Google OAuth (no Supabase)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3003/auth/google/callback

# JWT
JWT_SECRET=super-secret-jwt-key-change-me

# CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Dashboard URL (OAuth redirect target)
FRONTEND_URL=http://localhost:3001

# Platform fee (% deducted from each incoming payment, default 1.5)
PLATFORM_FEE_RATE=1.5

# Nomba (Nigeria banking)
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_SANDBOX=true
NOMBA_WEBHOOK_SECRET=

# Cloudflare R2 (image uploads — optional, falls back to local disk)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=paygrid-uploads
R2_PUBLIC_URL=
